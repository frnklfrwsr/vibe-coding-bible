{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-coding-bible.local/schemas/chapter.schema.json",
  "title": "VCB Chapter Frontmatter",
  "allOf": [
    {
      "$ref": "topic.schema.json"
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^vcb\\.chapter\\.[a-z0-9_]+$"
    },
    "type": {
      "const": "chapter"
    },
    "chapter_number": {
      "type": "integer",
      "minimum": 0,
      "maximum": 99
    },
    "audiences": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 2,
      "items": {
        "type": "string",
        "enum": [
          "human",
          "ai_coach"
        ]
      },
      "allOf": [
        {
          "contains": {
            "const": "human"
          }
        },
        {
          "contains": {
            "const": "ai_coach"
          }
        }
      ]
    },
    "attention_modes": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "continuous_supervision",
          "periodic_check_in",
          "low_attention_review_later",
          "unattended_requires_isolation"
        ]
      }
    },
    "evidence_basis": {
      "type": "string",
      "enum": [
        "VCB_SYNTHESIS_STABLE_ENGINEERING_PRACTICE"
      ]
    },
    "source_kind": {
      "type": "string",
      "enum": [
        "official_docs",
        "official_docs_plus_maintainer_synthesis",
        "maintainer_synthesis",
        "community_field_report",
        "expert_report",
        "local_reproduction",
        "speculative"
      ]
    },
    "evidence_scope": {
      "type": "string"
    }
  },
  "required": [
    "chapter_number",
    "audiences",
    "attention_modes"
  ]
}
